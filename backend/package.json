{
  "name": "disaster-response-backend",
  "version": "1.0.0",
  "description": "Smart Disaster Response MIS Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "server": "node server.js",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:triggers": "node prisma/migrations/002_triggers.js",
    "db:views": "prisma db execute --file ./prisma/migrations/001_views_triggers.sql --schema ./prisma/schema.prisma",
    "db:setup": "prisma generate && prisma db push && node prisma/migrations/002_triggers.js && node prisma/seed.js",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "studio": "prisma studio --port 5555"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0"
  }
}
